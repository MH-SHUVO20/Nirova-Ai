# Secrets — NEVER bake into Docker images
.env
.env.*
*.env
backend/.env
frontend/.env.local

# Version control
.git
.gitignore

# IDE / Editor
.vscode
.idea

# Infrastructure (not needed in containers)
infrastructure/
scripts/

# Documentation
*.md
LICENSE

# CI/CD workflows
.github/

# Azure config
.azure/

# Node modules (rebuilt in container)
frontend/node_modules/

# Python artifacts
**/__pycache__
**/*.pyc
**/*.pyo

# Build output (rebuilt in container)
frontend/dist/

# Tests
backend/tests/
backend/.pytest_cache/

# OS files
.DS_Store
Thumbs.db

# Large model files (pulled at runtime, not baked)
backend/app/models/*.onnx
backend/app/models/*.keras
