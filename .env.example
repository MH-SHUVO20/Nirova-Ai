# ─────────────────────────────────────────────────────────────
# NirovaAI — Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────

# ── Core App ──────────────────────────────────────────────────
APP_NAME=NirovaAI
DEBUG=false
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://nirovaai.app

# ── Frontend Runtime ─────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=your_mongo_atlas_connection_string
MONGODB_DB_NAME=nirovaai

# ── Auth / JWT ───────────────────────────────────────────────
SECRET_KEY=your-random-secret-key-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
AUTH_COOKIE_NAME=access_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ── Password Reset ──────────────────────────────────────────
PASSWORD_RESET_EXPIRE_MINUTES=20
PASSWORD_RESET_PATH=/reset-password
ENABLE_RESET_TOKEN_PREVIEW=false
ALLOW_PASSWORD_RESET_KBA_FALLBACK=false

# ── AI Providers ─────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AIzaSy...
OPENAI_API_KEY=
PRELOAD_EMBEDDER=false
HF_API_KEY=hf_...
HF_MODEL=Qwen/Qwen2.5-32B-Instruct
LLM_ROUTING_MODE=cloud_first

# ── Chat Orchestration ──────────────────────────────────────
CHAT_ORCHESTRATION_MODE=langgraph

# ── Docker: MongoDB & Redis Auth (docker-compose only) ──────
MONGO_INITDB_ROOT_USERNAME=nirovaai
MONGO_INITDB_ROOT_PASSWORD=change_me_use_a_strong_password
REDIS_PASSWORD=change_me_use_a_strong_password

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Cloudinary (optional) ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── SMTP (optional for forgot-password email) ───────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_USE_TLS=true

# ── Docker Registry (CI/CD) ─────────────────────────────────
# Used by GitHub Actions deploy pipeline
# DOCKER_REGISTRY=ghcr.io
# DOCKER_USERNAME=your-github-username
# DOCKER_PASSWORD=ghp_your_token
